{
  "name": "eslint-config-improvin",
  "version": "0.7.2",
  "description": "ESLint config used at Improvin",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    "types": "./index.d.ts",
    "require": "./index.cjs",
    "import": "./index.mjs",
    "default": "./index.mjs"
  },
  "files": [
    "base-config.cjs",
    "index.mjs",
    "index.cjs",
    "index.d.ts",
    "src"
  ],
  "scripts": {
    "lint": "eslint . --ignore-pattern 'tests/**'",
    "test:prettier-enforcement": "node ./scripts/check-prettier-enforcement.mjs"
  },
  "author": "Improvin AB",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "eslint": ">=10"
  },
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "minimatch": "^10.2.5",
    "prettier": "^3.9.5",
    "typescript": "^6.0"
  },
  "devDependencies": {
    "eslint": "^10.7.0"
  }
}
